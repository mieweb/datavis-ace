#!/bin/bash

show_help() {
	>&2 cat <<EOF
$(basename $0) - JavaScript Pre-Processor

USAGE: $(basename $0) <OPTIONS> <INPUT>

Reads the JavaScript file from <INPUT>, strips any extension, and writes its
content to <INPUT>.js - any lines matching the following criteria are handled
specially.

SPECIAL LINES:

    \$INCLUDE('...');

        Includes the file in quotes within the output.

OPTIONS:

    -h      Show this help message.
    -v      Verbose mode (information printed on stderr).
EOF
}

main() {
	local verbose=0
	local input_file=''
	local output_file=''
	local include_regexp='^\s*\$INCLUDE\('\''([A-Za-z0-9_./-]+)'\''\);\s*$'
	local include_file=''

	while getopts ':ho:v' opt; do
		case $opt in
			h) show_help ; exit 0 ;;
			o) output_file="$OPTARG" ;;
			v) verbose=1 ;;
			\?) >&2 echo "Invalid option: -$OPTARG" ; exit 1 ;;
			:) >&2 echo "Option -$OPTARG requires an argument" ; exit 1 ;;
			*) >&2 echo "Unimplemented option: -$OPTARG" ; exit 1 ;;
		esac
	done

	shift $((OPTIND-1))

	input_file="$1" ; shift

	if [[ -z $output_file ]]; then
		output_file="${input_file%.*}.js"
	fi

	prefix="$(dirname "$input_file")"

	if [[ $verbose = 1 ]]; then
		>&2 echo "Output file: $output_file"
	fi

	rm -f "$output_file"
	touch "$output_file"

	while IFS='' read -r line || [[ -n "$line" ]]; do
		if [[ $line =~ $include_regexp ]]; then
			include_file="${BASH_REMATCH[1]}"
			if [[ $verbose = 1 ]]; then
				>&2 echo "  Including file: $include_file"
			fi
			if [[ -n "$prefix" ]]; then
				include_file="$prefix/$include_file"
			fi
			if [[ ! -e "$include_file" ]]; then
				>&2 echo "Included file does not exist: $include_file"
				exit 1
			fi
			cat "$include_file" >> "$output_file"
		else
			cat <<< "$line" >> "$output_file"
		fi
	done < "$input_file"
}

main "$@"

