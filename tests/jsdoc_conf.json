{
    "plugins": [
        "plugins/markdown"
    ],
    "opts": {
        "template": "../third-party/jaguarjs-jsdoc",
        "destination": "jsdoc",
        "readme": "README.md"
    },
    "templates": {
        "systemName": "DataVis Test Lib",
        "copyright": "Copyright © Medical Informatics Engineering, Inc.",
        "theme": "spacelab",
        "linenums": true,
        "collapseSymbols": false,
        "inverseNav": true,
        "methodHeadingReturns": true,
        "outputSourceFiles": true,
        "applicationName": "DataVis Test Lib",
        "meta": {
            "title": "DataVis Test Lib JSDoc"
        },
        "default": {
            "outputSourceFiles": true
        }
    }
}
