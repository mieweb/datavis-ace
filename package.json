    "chai": "^4.3.4",
    "chromedriver": "^95.0.0",
    "es6-symbol": "3.1.3",
    "eslint": "8.1.0",
    "jsdoc": "3.6.7",
    "jshint": "2.13.1",
    "json5": "2.2.0",
    "lodash": "^4.17.21",
    "mermaid": "8.13.3",
    "micro": "9.3.4",
    "micro-dev": "3.0.0",
    "mocha": "9.1.3",
    "rollup": "2.59.0",
    "selenium-webdriver": "4.0.0",
