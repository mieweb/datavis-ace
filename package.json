    "jquery-ui": "^1.13.0",
    "moment": "^2.29.1",
    "numeral": "^2.0.6",
    "papaparse": "^5.3.1",
    "serve-handler": "^6.1.3",
    "sprintf-js": "^1.1.2",
    "sumoselect": "^3.3.30",
    "underscore": "^1.13.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "21.0.1",
    "@rollup/plugin-node-resolve": "13.0.6",
