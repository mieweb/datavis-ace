{
    "plugins": [
        "plugins/markdown"
    ],
    "opts": {
        "template": "jaguarjs-jsdoc",
        "destination": "jsdoc"
    },
    "templates": {
        "systemName": "WC DataVis",
        "copyright": "Copyright © Medical Informatics Engineering, Inc.",
        "theme": "spacelab",
        "linenums": true,
        "collapseSymbols": false,
        "inverseNav": true,
        "methodHeadingReturns": true,
        "outputSourceFiles": true
    }
}
